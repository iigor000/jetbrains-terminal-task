<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TerminalBuffer Full Suite">

    <test name="Initialization">
        <groups><run><include name="initialization"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Packing">
        <groups><run><include name="packing"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Character Writing">
        <groups><run><include name="characterWriting"/><include name="putText"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Insert Char">
        <groups><run><include name="insertChar"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Cursor Control">
        <groups><run><include name="cursorControl"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Clear Screen">
        <groups><run><include name="clearScreen"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Scrolling">
        <groups><run><include name="scrolling"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Content Access">
        <groups><run><include name="contentAccess"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Circular Buffer">
        <groups><run><include name="circularBuffer"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Edge Cases">
        <groups><run><include name="edgeCases"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

    <test name="Resize">
        <groups><run><include name="resize"/></run></groups>
        <classes><class name="org.terminal.TerminalBufferTest"/></classes>
    </test>

</suite>

